# Meta Supabase (supabase/ → 5432x)
NEXT_PUBLIC_META_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_META_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used for admin operations (user creation, etc.)
META_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time setup gate (min 32 chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETUP_SECRET=

# Target Supabase (supabase-target/ → 5442x) — UI 登録 or seed 用参考値
LOCAL_TARGET_SUPABASE_URL=http://127.0.0.1:54421
LOCAL_TARGET_SUPABASE_ANON_KEY=your-target-anon-key
LOCAL_TARGET_SUPABASE_SERVICE_ROLE_KEY=your-target-service-role-key

# Drizzle / Vitest
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# AES-256-GCM key for encrypting connection keys (32-byte hex = 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional: extra CSP connect-src origins for custom Target URLs (comma-separated)
# CSP_EXTRA_CONNECT_SRC=https://my-target.example.com

NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# CI build skip (optional)
# SKIP_ENV_VALIDATION=true
