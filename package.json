{
  "name": "supa-admin",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "test": "tsx scripts/test-with-supabase.ts",
    "test:turbo": "turbo test",
    "test:coverage": "turbo test -- --coverage",
    "test:unit": "turbo test --filter=!@supa-admin/auth --filter=!@supa-admin/repository-kit -- --coverage",
    "test:integration": "turbo test --filter=@supa-admin/auth --filter=@supa-admin/repository-kit -- --coverage",
    "dev": "turbo dev --parallel",
    "format": "biome check --write --unsafe",
    "lint": "biome check",
    "lint:arch": "depcruise packages apps --config .dependency-cruiser.cjs",
    "architecture-check": "tsx scripts/architecture-check.ts",
    "check:edge-bundle": "tsx scripts/check-edge-bundle.ts",
    "typecheck": "turbo typecheck",
    "db:start": "tsx scripts/db-start.ts",
    "db:start:meta": "tsx scripts/db-start-meta.ts",
    "db:start:target": "tsx scripts/db-start-target.ts",
    "db:stop": "tsx scripts/db-stop.ts",
    "db:reset": "tsx scripts/db-reset-meta.ts",
    "db:reset:target": "tsx scripts/db-reset-target.ts",
    "setup:env": "tsx scripts/setup-env.ts",
    "setup:env-local": "tsx scripts/setup-env-local.ts",
    "setup:local": "tsx scripts/setup-local.ts",
    "verify:dod": "tsx scripts/verify-dod-scenarios.ts",
    "db:push": "pnpm --filter @supa-admin/db db:push",
    "ai-context:generate": "tsx .ai-context/scripts/index.ts"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "zod": "4"
      }
    },
    "overrides": {
      "zod": "4.4.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "dependency-cruiser": "^17.4.3",
    "@dotenvx/dotenvx": "^1.34.0",
    "@vitest/coverage-v8": "^3.2.4",
    "lefthook": "^1.12.2",
    "tsx": "^4.7.1",
    "turbo": "^2.5.5",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
